{
  "name": "keri-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "clean": "node scripts/clean.ts",
    "test:interop": "npm run test:interop --workspace packages/keri",
    "test:integration": "npm run test:integration --workspace packages/keri",
    "lint": "eslint packages/",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11",
      "onFail": "warn"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.30",
    "concurrently": "^9.2.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "serve": "^14.2.5",
    "typedoc": "^0.28.14",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
