{
  "name": "keri-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "clean": "node scripts/clean.ts",
    "test:interop": "npm run test:interop --workspace packages/keri",
    "test:integration": "npm run test:integration --workspace packages/keri",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11",
      "onFail": "warn"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^22.15.30",
    "concurrently": "^9.2.1",
    "serve": "^14.2.5",
    "typedoc": "^0.28.14",
    "typescript": "^6.0.2"
  }
}
