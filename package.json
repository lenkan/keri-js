{
  "name": "keri",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lenkan/keri-js.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "node --test --no-warnings 'src/**/*.test.ts'",
    "test:interop": "node --test --test-concurrency=1 --no-warnings 'test_interop/test_*.ts'",
    "test:vector": "node --test --no-warnings 'test_vectors/**/*.test.ts'",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "tsc --noEmit",
    "clean": "node scripts/clean.ts",
    "format": "biome format --write .",
    "docs:build": "typedoc",
    "docs:serve": "concurrently \"serve docs\" \"typedoc --watch --preserveWatchOutput\""
  },
  "exports": {
    ".": "./dist/main.js",
    "./sqlite-storage": "./dist/storage/sqlite/storage-sqlite.js",
    "./witness": "./dist/witness/main.js",
    "./nodejs-utils": "./dist/nodejs-utils/serve.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "author": "Daniel Lenksjö",
  "license": "Apache-2.0",
  "description": "KERI for JavaScript",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@noble/curves": "^2.0.0",
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.0",
    "@noble/secp256k1": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/debug": "^4.1.13",
    "@types/node": "^22.15.30",
    "concurrently": "^9.2.1",
    "debug": "^4.4.3",
    "serve": "^14.2.5",
    "typedoc": "^0.28.14",
    "typescript": "^6.0.2"
  }
}
